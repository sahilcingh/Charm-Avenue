# Copy this file to .env and fill in real values. Never commit the real .env
# (it's already gitignored).

# ── Required — the app will not function without these ──────────────────────

# Supabase project (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your production domain — used for sitemap.xml, robots.txt, and Open Graph
# image URLs. Falls back to http://localhost:3000 if unset, so the app still
# builds without it, but sitemap/social-share links will be wrong in prod.
NEXT_PUBLIC_SITE_URL=

# WhatsApp number the cart's "Enquire on WhatsApp" button messages,
# digits only or with a country code — src/lib/whatsapp.ts strips non-digits.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Supabase Dashboard → Settings → API → service_role key. Server-side only,
# NEVER exposed to the client (src/lib/supabase/service-client.ts guards this
# with the `server-only` package). Used by the guest order-confirmation page
# (src/app/order/[id]/page.tsx) to look up any order — including a guest's,
# who has no session — by its own unguessable id, bypassing RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional dev-only overrides ──────────────────────────────────────────────

# Override the Next.js build output directory (defaults to .next).
DIST_DIR=
# Comma-separated paths for the dev server's file watcher to ignore.
WATCH_IGNORED_PATHS=
