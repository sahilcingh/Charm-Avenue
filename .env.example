# Copy this file to .env and fill in real values. Never commit the real .env
# (it's already gitignored).

# ── Required — the app will not function without these ──────────────────────

# Supabase project (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your production domain — used for sitemap.xml, robots.txt, and Open Graph
# image URLs. Falls back to http://localhost:3000 if unset, so the app still
# builds without it, but sitemap/social-share links will be wrong in prod.
NEXT_PUBLIC_SITE_URL=

# WhatsApp number the "Enquire via WhatsApp" checkout path messages,
# digits only or with a country code — src/lib/whatsapp.ts strips non-digits.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ── Required only for the Cashfree payment webhook (currently on hold) ─────

# Supabase Dashboard → Settings → API → service_role key. Server-side only,
# NEVER exposed to the client (src/lib/supabase/service-client.ts guards this
# with the `server-only` package). Only used by the Cashfree webhook
# (src/app/api/webhooks/cashfree/route.ts), which has no logged-in session to
# mark a customer's order paid. Not needed for checkout, order creation, or
# viewing your own order history — those all use the signed-in customer's own
# session and RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ── Not active until set — online payment ("Pay Now" at checkout) ──────────
#
# Payment integration is currently ON HOLD. Leaving these unset is the normal,
# supported state: the "Pay Now" button simply does not render (see
# paymentEnabled in src/app/checkout/page.tsx) — checkout still works
# completely via "Enquire via WhatsApp" alone. Only fill these in once
# Cashfree onboarding (KYC) is actually complete.

CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
# From the webhook's config screen in the Cashfree dashboard, once the
# webhook endpoint (/api/webhooks/cashfree) is registered there.
CASHFREE_WEBHOOK_SECRET=
# Optional. Defaults to the production API. Override to Cashfree's sandbox
# host (https://sandbox.cashfree.com/pg) while testing with sandbox keys.
CASHFREE_API_BASE_URL=
# Optional, client-side. Must be NEXT_PUBLIC_ to reach the browser (this is
# what selects sandbox vs production mode in Cashfree's Checkout JS SDK —
# separate from CASHFREE_API_BASE_URL above, which is the server-side API
# host). Defaults to "sandbox" unless set to exactly "production".
NEXT_PUBLIC_CASHFREE_MODE=

# ── Optional dev-only overrides ──────────────────────────────────────────────

# Override the Next.js build output directory (defaults to .next).
DIST_DIR=
# Comma-separated paths for the dev server's file watcher to ignore.
WATCH_IGNORED_PATHS=
